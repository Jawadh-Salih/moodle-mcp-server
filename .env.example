# Moodle MCP Server Configuration
# Copy this file to .env and fill in your values

# Your Moodle instance URL (required)
MOODLE_URL=https://moodle.youruniversity.edu

# Option 1: Provide a token directly (if you have one)
# MOODLE_TOKEN=your-api-token-here

# Option 2: Provide credentials (the server will obtain a token automatically)
# MOODLE_USERNAME=your-username
# MOODLE_PASSWORD=your-password

# Note: You can also skip all of the above and use the "login" tool
# interactively through Claude to provide your credentials at runtime.
